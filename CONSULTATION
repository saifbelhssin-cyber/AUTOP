            <div class="info-box-value" id="dashVehicule">-</div>
            <div class="info-box-desc" id="dashAnnee">-</div>
          </div>
          <div class="info-box">
            <div class="info-box-title">📦 Pièces demandées</div>
            <div class="info-box-value" id="dashNbPieces">0</div>
            <div class="info-box-desc" id="dashUrgence">-</div>
          </div>
        </div>

        <!-- TIMELINE DE SUIVI COMPLET -->
        <h4 style="font-size: 16px; font-weight: 700; margin-bottom: 20px; color: var(--dark);">📊 État d'avancement</h4>
        
        <div class="timeline">
          <!-- 1. DEMANDE -->
          <div class="timeline-item active">
            <div class="timeline-title">✓ Demande de Devis Reçue</div>
            <div class="timeline-desc" id="statusDevis1">Votre demande a été enregistrée dans notre système</div>
            <div class="timeline-date" id="dateDevis">-</div>
            <span class="status-badge badge-success" id="badgeDevis">CONFIRMÉE</span>
          </div>

          <!-- 2. ANALYSE ET DEVIS -->
          <div class="timeline-item" id="timelineAnalyse">
            <div class="timeline-title">Étape 2 - Analyse et Préparation du Devis</div>
            <div class="timeline-desc">Nos équipes examinent votre demande et les références pièces</div>
            <div class="timeline-date" id="dateAnalyse">-</div>
            <span class="status-badge badge-process" id="badgeAnalyse">EN COURS</span>
          </div>

          <!-- 3. DEVIS PROPOSÉ -->
          <div class="timeline-item" id="timelineDevisPropose">
            <div class="timeline-title">Devis Commercial Envoyé</div>
            <div class="timeline-desc" id="statusDevis3">Vous recevrez le devis par email avec tarifs et délais</div>
            <div class="timeline-date" id="dateDevisPropose">-</div>
            <span class="status-badge badge-pending" id="badgeDevisPropose">EN ATTENTE VALIDATION</span>
            <div id="invoiceContainer1"></div>
          </div>

          <!-- 4. COMMANDE CONFIRMÉE -->
          <div class="timeline-item" id="timelineCommande">
            <div class="timeline-title">Commande Créée et Confirmée</div>
            <div class="timeline-desc" id="statusCommande">Votre commande est enregistrée auprès de nos fournisseurs</div>
            <div class="timeline-date" id="dateCommande">-</div>
            <span class="status-badge badge-pending" id="badgeCommande">ATTENTE</span>
            <div id="orderInfoContainer"></div>
          </div>

          <!-- 5. PRÉPARATION -->
          <div class="timeline-item" id="timelinePrepare">
            <div class="timeline-title">Préparation et Conditionnement</div>
            <div class="timeline-desc">Les pièces sont préparées et emballées selon les normes</div>
            <div class="timeline-date" id="datePrepare">-</div>
            <span class="status-badge badge-pending" id="badgePrepare">ATTENTE</span>
          </div>

          <!-- 6. EXPÉDITION -->
          <div class="timeline-item" id="timelineShipped">
            <div class="timeline-title">🚚 Expédition en Cours</div>
            <div class="timeline-desc" id="statusShipped">Votre colis a quitté notre entrepôt</div>
            <div class="timeline-date" id="dateShipped">-</div>
            <span class="status-badge badge-shipped" id="badgeShipped">ATTENTE</span>
            <div id="shippingContainer"></div>
          </div>

          <!-- 7. LIVRAISON -->
          <div class="timeline-item" id="timelineDelivery">
            <div class="timeline-title">✓ Livraison Effectuée</div>
            <div class="timeline-desc" id="statusDelivery">Colis remis au client</div>
            <div class="timeline-date" id="dateDelivery">-</div>
            <span class="status-badge badge-pending" id="badgeDelivery">ATTENTE</span>
          </div>

          <!-- 8. FACTURE & PAIEMENT -->
          <div class="timeline-item" id="timelineInvoice">
            <div class="timeline-title">💳 Facture et Paiement</div>
            <div class="timeline-desc" id="statusInvoice">Facture disponible et suivi de paiement</div>
            <div class="timeline-date" id="dateInvoice">-</div>
            <span class="status-badge badge-pending" id="badgeInvoice">ATTENTE</span>
            <div id="invoiceContainer2"></div>
          </div>
        </div>

      </div>

    </div>
  </div>
</div>

