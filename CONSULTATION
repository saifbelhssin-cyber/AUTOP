    <div class="tracking-card">
      <h3>🔍 Espace Client - Suivi Complet</h3>
      <p style="color: var(--text-muted); font-size: 14px; margin-bottom: 12px;">Consultez en temps réel l'état de votre demande, commande, livraison et facture.</p>
      <div class="search-group">
        <input type="text" id="trackingInput" placeholder="Saisissez votre N° de demande (ex: DEM-20260705-001)">
        <button class="search-btn" onclick="trackDossier()">Consulter mon dossier</button>
      </div>

      <!-- DASHBOARD SUIVI CLIENT INTERACTIF -->
      <div class="client-dashboard" id="clientDashboard">
        
        <!-- INFORMATIONS CLIENT ET VEHICLE -->
        <div class="info-grid" style="margin-bottom: 32px;">
          <div class="info-box">
