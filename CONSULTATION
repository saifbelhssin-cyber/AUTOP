      </div>
      <nav class="nav-links">
        <a href="admin.html">Espace Pro</a>
      </nav>
    </div>
  </div>
</header>

<!-- TRACKING SECTION -->
<div class="tracking-section">
  <div class="tracking-container">
    <div>
      <div class="tracking-box">
        <h3>🔍 Suivi de votre devis</h3>
        <input type="text" id="trackingInput" placeholder="Entrez votre numéro de devis (ex: DEM-20260701-001)">
        <button class="search-btn" onclick="trackDevis()">Rechercher</button>
      </div>
    </div>
    <div class="tracking-result" id="trackingResult">
      <div class="tracking-box">
        <h3>📊 Détails de votre devis</h3>
        <div class="status-info">
          <div class="status-label">État d'avancement</div>
          <div class="status-value">
            <span class="status-badge" id="resultStatus" style="display: inline-block;"></span>
          </div>
        </div>
        <div class="status-info">
          <div class="status-label">Date</div>
          <div class="status-value" id="resultDate"></div>
        </div>
        <div class="status-info">
          <div class="status-label">Nombre de pièces</div>
          <div class="status-value" id="resultPieces"></div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- HERO -->
<div class="hero">
  <h1>Demande de Devis — Pièces Auto</h1>
  <p>Rapide • Sécurisé • Suivi en temps réel</p>
  <div class="trust-badges">
    <div><span>✅ 100%</span> Gratuit</div>
    <div><span>⚡ Réponse</span> en 2h</div>
    <div><span>📞 Support</span> 24/7</div>
  </div>
</div>

<!-- FEATURES -->
<div class="features">
  <div class="feature">
    <div class="feature-icon">⚡</div>
    <h3>Rapide</h3>
    <p>Remplissez en 2 min</p>
  </div>
  <div class="feature">
    <div class="feature-icon">🔒</div>
    <h3>Sécurisé</h3>
    <p>Vos données protégées</p>
  </div>
  <div class="feature">
    <div class="feature-icon">📞</div>
    <h3>Support</h3>
    <p>Contact immédiat</p>
  </div>
  <div class="feature">
    <div class="feature-icon">💰</div>
    <h3>Gratuit</h3>
    <p>Aucun frais caché</p>
  </div>
</div>

<!-- FORM -->
<div class="container">
  <form id="demandeForm" onsubmit="return submitDemande(event)">

    <!-- INFORMATIONS CLIENT -->
    <div class="form-group">
      <h3 style="margin-bottom: 16px; color: #d32f2f;">📋 Vos informations</h3>
      <div class="form-row">
        <div>
          <label for="nom" class="required">Nom complet</label>
          <input type="text" id="nom" name="nom" required>
        </div>
        <div>
          <label for="email" class="required">Email</label>
          <input type="email" id="email" name="email" required>
        </div>
        <div>
          <label for="telephone" class="required">Téléphone</label>
          <input type="tel" id="telephone" name="telephone" required>
        </div>
      </div>
    </div>

    <!-- INFORMATIONS VÉHICULE -->
    <div class="form-group">
      <h3 style="margin-bottom: 16px; color: #d32f2f;">🚗 Informations du véhicule</h3>
      <div class="form-row">
        <div>
          <label for="marque" class="required">Marque</label>
          <input type="text" id="marque" name="marque" placeholder="ex: Renault" required>
        </div>
        <div>
          <label for="modele" class="required">Modèle</label>
          <input type="text" id="modele" name="modele" placeholder="ex: Clio" required>
        </div>
        <div>
          <label for="annee" class="required">Année</label>
          <input type="number" id="annee" name="annee" min="1990" max="2050" placeholder="ex: 2020" required>
        </div>
        <div>
          <label for="kilometrage">Kilométrage</label>
          <input type="number" id="kilometrage" name="kilometrage" placeholder="ex: 50000">
        </div>
      </div>
    </div>

    <!-- PIÈCES DEMANDÉES -->
    <div class="pieces-section">
      <h3>🔧 Pièces demandées</h3>
      <div id="piecesContainer">
        <div class="piece-row" data-piece-id="1">
          <input type="text" class="piece-des" placeholder="Désignation de la pièce" required>
          <input type="text" class="piece-ref" placeholder="Référence OEM">
          <input type="number" class="piece-qte" placeholder="Quantité" value="1" min="1" required>
          <select class="piece-urg">
            <option value="Normal">Normal</option>
            <option value="Urgent">Urgent ⚡</option>
          </select>
          <button type="button" class="btn-remove" onclick="removePiece(this)" style="opacity: 0; pointer-events: none;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
          </button>
        </div>
      </div>
      <button type="button" class="btn-add-piece" onclick="addPiece()">+ Ajouter une pièce</button>
    </div>

    <!-- FILE UPLOAD SECTION -->
    <div class="files-section">
      <h3>📸 Photos et Documents (Optionnel)</h3>
      <p>Téléchargez des photos ou documents pour faciliter le devis<br><small>(Images, PDF, Word, etc.)</small></p>
      <div class="file-input-wrapper">
        <input type="file" id="fileInput" multiple accept="image/*,.pdf,.doc,.docx,.xls,.xlsx" onchange="handleFileSelect(event)">
        <button type="button" class="file-upload-btn" onclick="document.getElementById('fileInput').click()">
          📁 Choisir des fichiers
        </button>
      </div>
      <div class="max-files-info">Maximum 10 fichiers, 5 MB par fichier</div>
      <div class="files-list" id="filesList"></div>
    </div>

    <!-- MESSAGE -->
    <div class="form-group">
      <label for="message">Message supplémentaire</label>
      <textarea id="message" name="message" placeholder="Décrivez votre demande en détail..."></textarea>
    </div>

    <!-- BUTTONS -->
    <div class="actions">
      <button type="submit" class="btn btn-primary">📤 Envoyer mon devis</button>
      <button type="reset" class="btn btn-outline">Réinitialiser</button>
    </div>
  </form>
</div>

<!-- CONFIRMATION -->
<div class="confirmation" id="confirmation">
  <div class="confirmation-content">
    <h2>✅ Demande envoyée avec succès !</h2>
    <p>Votre numéro de suivi :</p>
    <div class="num" id="numDemande">DEM-20260705-001</div>
    <p>Nous vous contacterons sous <strong>2 heures</strong> par email ou téléphone.</p>
    <p style="color: #666; font-size: 13px; margin-top: 12px;">📱 Vous pouvez suivre votre demande en haut de cette page avec ce numéro.</p>

    <div class="send-options">
      <button class="btn btn-outline" id="btnEmailAutop">📧 Envoyer par email</button>
      <button class="btn btn-outline" id="btnWhats1">💬 WhatsApp #1</button>
      <button class="btn btn-outline" id="btnWhats2">💬 WhatsApp #2</button>
    </div>

    <div class="actions" style="justify-content: center; margin-top: 24px;">
      <button class="btn btn-primary" onclick="nouvelleDemande()">Nouvelle demande</button>
      <button class="btn btn-outline" onclick="window.location.href='admin.html'">Accès Espace Pro</button>
    </div>
  </div>
</div>

<!-- FOOTER -->
<footer class="footer">
  <div class="footer-content">
    <p>AUTOP — Vente de pièces automobiles</p>
    <div class="footer-links">
      <a href="mailto:comptoir.distribution@autop.tn">📧 Email</a>
      <a href="https://wa.me/21698774525">💬 WhatsApp</a>
    </div>
    <div class="footer-links" style="margin-top: 8px;">
      <a href="admin.html">🔑 Accès espace professionnel</a>
    </div>
    <p style="margin-top: 16px; font-size: 12px; color: #888;">© 2026 AUTOP. Tous droits réservés.</p>
  </div>
</footer>

<div class="toast" id="toast"></div>

<script>
let pieceCount = 1;
let uploadedFiles = [];
const MAX_FILES = 10;
const MAX_FILE_SIZE = 5 * 1024 * 1024; // 5 MB

function handleFileSelect(event) {
  const files = Array.from(event.target.files);
  
  // Validate number of files
  if (uploadedFiles.length + files.length > MAX_FILES) {
    showToast(`❌ Maximum ${MAX_FILES} fichiers autorisés`, 'error');
    return;
  }

  // Validate file sizes and add files
  files.forEach((file, index) => {
    if (file.size > MAX_FILE_SIZE) {
      showToast(`❌ ${file.name}: fichier trop volumineux (max 5 MB)`, 'error');
      return;
    }

    // Convert file to base64 for storage
    const reader = new FileReader();
    reader.onload = function(e) {
      uploadedFiles.push({
        name: file.name,
        size: file.size,
        type: file.type,
        data: e.target.result
      });
      renderFiles();
    };
    reader.readAsDataURL(file);
  });

  // Reset input
  event.target.value = '';
}

function renderFiles() {
  const list = document.getElementById('filesList');
  list.innerHTML = uploadedFiles.map((file, i) => `
    <div class="file-item">
      ${file.name.substring(0, 20)}
      <button type="button" class="file-remove-btn" onclick="removeFile(${i})">✕</button>
    </div>
  `).join('');
}

function removeFile(index) {
  uploadedFiles.splice(index, 1);
  renderFiles();
}

function addPiece() {
  pieceCount++;
  const html = `
    <div class="piece-row" data-piece-id="${pieceCount}">
      <input type="text" class="piece-des" placeholder="Désignation de la pièce" required>
      <input type="text" class="piece-ref" placeholder="Référence OEM">
      <input type="number" class="piece-qte" placeholder="Quantité" value="1" min="1" required>
      <select class="piece-urg">
        <option value="Normal">Normal</option>
        <option value="Urgent">Urgent ⚡</option>
      </select>
      <button type="button" class="btn-remove" onclick="removePiece(this)">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
      </button>
    </div>
  `;
  document.getElementById('piecesContainer').insertAdjacentHTML('beforeend', html);
  updateRemoveButtons();
}

function removePiece(btn) { 
  const row = btn.closest('.piece-row'); 
  if(row){ row.remove(); updateRemoveButtons(); }
}

function updateRemoveButtons() { 
  const rows = document.querySelectorAll('.piece-row'); 
  rows.forEach((row) => { 
    const btn = row.querySelector('.btn-remove'); 
    if(!btn) return; 
    if(rows.length === 1){ 
      btn.style.opacity = '0'; 
      btn.style.pointerEvents = 'none'; 
    } else { 
      btn.style.opacity = '1'; 
      btn.style.pointerEvents = 'auto'; 
    } 
  }); 
}

function showToast(msg, type) { 
  const t = document.getElementById('toast'); 
  t.textContent = msg; 
  t.className = 'toast ' + (type || 'success'); 
  t.classList.add('show'); 
  setTimeout(() => t.classList.remove('show'), 3000); 
}

function trackDevis() {
  const num = document.getElementById('trackingInput').value.trim();
  if (!num) {
    showToast('❌ Veuillez entrer un numéro de devis', 'error');
    return;
  }

  const demandes = JSON.parse(localStorage.getItem('demandes') || '[]');
  const demande = demandes.find(d => d.num === num);

  if (!demande) {
    showToast('❌ Devis introuvable', 'error');
    document.getElementById('trackingResult').classList.remove('show');
    return;
  }

  document.getElementById('resultStatus').textContent = demande.statut || 'En attente';
  document.getElementById('resultDate').textContent = demande.date;
  document.getElementById('resultPieces').textContent = (demande.pieces || []).length;
  document.getElementById('trackingResult').classList.add('show');
  showToast('✅ Devis trouvé !', 'success');
}

function submitDemande(e) {
  e.preventDefault();
  const now = new Date();
  const num = 'DEM-' + now.toISOString().slice(0,10).replace(/-/g,'') + '-' + String(Math.floor(Math.random()*900)+100).padStart(3,'0');
  document.getElementById('numDemande').textContent = num;

  const pieces = [];
  document.querySelectorAll('.piece-row').forEach(row => {
    const des = row.querySelector('.piece-des').value;
    const ref = row.querySelector('.piece-ref').value;
    const qte = row.querySelector('.piece-qte').value;
    const urg = row.querySelector('.piece-urg').value;
    if (des) pieces.push({ des, ref, qte, urg });
  });

  const demande = {
    num: num,
    date: now.toLocaleDateString('fr-FR'),
    heure: now.toLocaleTimeString('fr-FR', {hour:'2-digit', minute:'2-digit'}),
    client: document.getElementById('nom').value,
    email: document.getElementById('email').value,
    telephone: document.getElementById('telephone').value,
    vehicule: document.getElementById('marque').value + ' ' + document.getElementById('modele').value,
    annee: document.getElementById('annee').value,
    pieces: pieces,
    files: uploadedFiles,
    message: document.getElementById('message').value,
    statut: 'En attente'
  };

  try {
    const demandes = JSON.parse(localStorage.getItem('demandes') || '[]');
    demandes.unshift(demande);
    localStorage.setItem('demandes', JSON.stringify(demandes));

    try {
      const bc = new BroadcastChannel('demandes_channel');
      bc.postMessage({ type: 'nouvelle_demande', demande });
      bc.close();
    } catch(e) {}

    resetForm();
    document.getElementById('demandeForm').style.display = 'none';
    document.getElementById('confirmation').classList.add('show');
    showToast('✅ Demande envoyée !', 'success');
    window.scrollTo({ top: 0, behavior: 'smooth' });

    setupConfirmationActions(demande);
  } catch(e) {
    console.error('Erreur:', e);
    showToast('❌ Erreur lors de l\'envoi', 'error');
  }
  return false;
}

function setupConfirmationActions(demande) {
  const emailBtn = document.getElementById('btnEmailAutop');
  const waBtn1 = document.getElementById('btnWhats1');
  const waBtn2 = document.getElementById('btnWhats2');
  const autopEmail = 'comptoir.distribution@autop.tn';
  const waNum1 = '+21698774525';
  const waNum2 = '+21698171411';
  const subject = encodeURIComponent('Nouvelle demande de devis - ' + demande.num);
  const bodyLines = [];
  bodyLines.push('🔔 *NOUVELLE DEMANDE DE DEVIS*');
  bodyLines.push('');
  bodyLines.push('📋 *Numéro:* ' + demande.num);
  bodyLines.push('👤 *Client:* ' + (demande.client || ''));
  bodyLines.push('📞 *Tel:* ' + (demande.telephone || ''));
  bodyLines.push('📧 *Email:* ' + (demande.email || ''));
  bodyLines.push('🚗 *Véhicule:* ' + (demande.vehicule || '') + ' (' + (demande.annee || '') + ')');
  bodyLines.push('');
  bodyLines.push('🔧 *Pièces demandées:*');
  (demande.pieces || []).forEach(p => { 
    bodyLines.push('  • ' + p.des + ' (qte: ' + p.qte + ', ' + p.urg + ')'); 
  });
  if (demande.files && demande.files.length > 0) {
    bodyLines.push('');
    bodyLines.push('📎 *Fichiers attachés:* ' + demande.files.length + ' fichier(s)');
  }
  bodyLines.push('');
  bodyLines.push('💬 *Message:* ' + (demande.message || 'N/A'));
  bodyLines.push('');
  bodyLines.push('⏰ *Date:* ' + demande.date + ' ' + demande.heure);
  
  const body = encodeURIComponent(bodyLines.join('\n'));

  emailBtn.onclick = function() { 
    window.open('mailto:' + autopEmail + '?subject=' + subject + '&body=' + body, '_blank'); 
    showToast('📧 Ouverture email...', 'success');
  };
  waBtn1.onclick = function() { 
    window.open('https://wa.me/' + waNum1.replace(/\+/g,'') + '?text=' + body, '_blank'); 
    showToast('💬 Ouverture WhatsApp...', 'success');
  };
  waBtn2.onclick = function() { 
    window.open('https://wa.me/' + waNum2.replace(/\+/g,'') + '?text=' + body, '_blank'); 
    showToast('💬 Ouverture WhatsApp...', 'success');
  };
}

function resetForm() { 
  document.getElementById('demandeForm').reset(); 
  uploadedFiles = [];
  document.getElementById('filesList').innerHTML = '';
  document.getElementById('piecesContainer').innerHTML = `
    <div class="piece-row" data-piece-id="1">
      <input type="text" class="piece-des" placeholder="Désignation de la pièce" required>
      <input type="text" class="piece-ref" placeholder="Référence OEM">
      <input type="number" class="piece-qte" placeholder="Quantité" value="1" min="1" required>
      <select class="piece-urg">
        <option value="Normal">Normal</option>
        <option value="Urgent">Urgent ⚡</option>
      </select>
      <button type="button" class="btn-remove" onclick="removePiece(this)" style="opacity: 0; pointer-events: none;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
      </button>
    </div>
  `; 
  pieceCount = 1; 
  updateRemoveButtons(); 
}

function nouvelleDemande() { 
  resetForm(); 
  document.getElementById('demandeForm').style.display = 'block'; 
  document.getElementById('confirmation').classList.remove('show'); 
  window.scrollTo({ top: 0, behavior: 'smooth' }); 
}

document.addEventListener('DOMContentLoaded', function() { 
  updateRemoveButtons(); 
  document.getElementById('trackingInput').addEventListener('keypress', function(e) {
    if (e.key === 'Enter') trackDevis();
  });
});
</script>

</body>
</html>
