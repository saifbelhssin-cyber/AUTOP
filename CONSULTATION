    </div>

    <!-- INFORMATIONS VÉHICULE -->
    <div style="margin-bottom: 32px;">
      <h3 class="form-section-title">🚗 Identification du véhicule</h3>
      <div class="form-row">
        <div>
          <label for="marque" class="required">Marque</label>
          <input type="text" id="marque" placeholder="ex: Volkswagen" required>
        </div>
        <div>
          <label for="modele" class="required">Modèle</label>
          <input type="text" id="modele" placeholder="ex: Golf 8" required>
        </div>
        <div>
          <label for="annee" class="required">Année</label>
          <input type="number" id="annee" min="1990" max="2050" placeholder="ex: 2022" required>
        </div>
        <div>
          <label for="kilometrage">Kilométrage</label>
          <input type="number" id="kilometrage" placeholder="ex: 85000">
        </div>
      </div>
    </div>

    <!-- PIÈCES DEMANDÉES -->
    <div class="pieces-section">
      <h3 style="font-size: 15px; margin-bottom: 16px; color: var(--dark);">🔧 Liste des pièces recherchées</h3>
      <div id="piecesContainer">
        <div class="piece-row" data-piece-id="1">
          <div>
            <label class="required">Désignation</label>
            <input type="text" class="piece-des" placeholder="ex: Filtre à huile" required>
          </div>
          <div>
            <label>Référence (Optionnel)</label>
            <input type="text" class="piece-ref" placeholder="OEM / Réf constructeur">
          </div>
          <div>
            <label class="required">Quantité</label>
            <input type="number" class="piece-qte" value="1" min="1" required>
          </div>
          <div>
            <label>Priorité</label>
            <select class="piece-urg">
              <option value="Normal">Normal</option>
              <option value="Urgent">Urgent ⚡</option>
            </select>
          </div>
          <button type="button" class="btn-remove" onclick="removePiece(this)" style="opacity: 0; pointer-events: none;">✕</button>
        </div>
      </div>
      <button type="button" class="btn-add-piece" onclick="addPiece()">+ Ajouter une autre pièce</button>
    </div>

    <!-- PIÈCES JOINTES -->
    <div class="files-section">
      <h3 style="font-size: 16px; color: var(--dark); margin-bottom: 8px;">📸 Carte grise ou Photos des pièces</h3>
      <p style="color: var(--text-muted); font-size: 13px; margin-bottom: 16px;">Ajoutez des documents clairs pour éviter toute erreur de référence.</p>
      <input type="file" id="fileInput" multiple accept="image/*,.pdf" style="display: none;" onchange="handleFileSelect(event)">
      <button type="button" class="file-upload-btn" onclick="document.getElementById('fileInput').click()">📁 Sélectionner des fichiers</button>
      <div class="files-list" id="filesList" style="margin-top: 12px; display: flex; gap: 8px; justify-content: center; flex-wrap: wrap;"></div>
    </div>

    <!-- MESSAGE -->
    <div style="margin-bottom: 32px;">
      <label for="message">Notes complémentaires / Numéro de Châssis (VIN)</label>
      <textarea id="message" rows="3" placeholder="Précisez ici toute information utile (Motorisation, Version...)"></textarea>
    </div>

    <!-- ACTIONS -->
    <div class="actions">
      <button type="reset" class="btn btn-outline">Réinitialiser</button>
      <button type="submit" class="btn btn-primary">📤 Envoyer ma demande de devis</button>
    </div>
  </form>
</div>

<!-- MODAL CONFIRMATION -->
<div class="confirmation" id="confirmation">
  <div class="confirmation-content">
    <div style="font-size: 40px; margin-bottom: 16px;">🎯</div>
    <h2>Demande enregistrée !</h2>
    <p style="color: var(--text-muted); margin-top: 8px;">Voici votre numéro de dossier unique pour le suivi en ligne :</p>
    <div class="num" id="numDemande">-</div>
    <p style="font-size: 14px; margin-bottom: 20px;">Conservez-le précieusement. Nos équipes étudient votre dossier.</p>

    <div style="display: flex; gap: 8px; flex-wrap: wrap; justify-content: center; margin-bottom: 24px;">
      <button class="btn btn-outline" id="btnEmailAutop" style="padding: 10px 16px; font-size: 13px;">✉️ Transmettre par Mail</button>
      <button class="btn btn-outline" id="btnWhats1" style="padding: 10px 16px; font-size: 13px;">💬 WhatsApp</button>
    </div>

    <button class="btn btn-primary" style="width: 100%;" onclick="nouvelleDemande()">Créer une nouvelle demande</button>
  </div>
</div>

<footer class="footer">
  <p>© 2026 AUTOP Premium — Comptoir de distribution de pièces automobiles.</p>
  <div class="footer-links" style="margin-top: 12px;">
    <a href="mailto:comptoir.distribution@autop.tn">Contact Mail</a> | 
    <a href="admin.html">Portail d'administration</a>
  </div>
</footer>

<div class="toast" id="toast"></div>

<script>
let pieceCount = 1;
let uploadedFiles = [];

function showToast(msg, type = 'success') {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.className = `toast ${type} show`;
  setTimeout(() => t.classList.remove('show'), 4000);
}

function handleFileSelect(e) {
  const files = Array.from(e.target.files);
  files.forEach(file => {
    if(file.size > 5 * 1024 * 1024) {
      showToast(`Fichier ${file.name} trop lourd (max 5Mo)`, 'error');
      return;
    }
    const reader = new FileReader();
    reader.onload = function(evt) {
      uploadedFiles.push({ name: file.name, data: evt.target.result });
      renderFiles();
    };
    reader.readAsDataURL(file);
  });
  e.target.value = '';
}

function renderFiles() {
  const list = document.getElementById('filesList');
  list.innerHTML = uploadedFiles.map((f, i) => `
    <span style="background:#e2e8f0; padding:4px 10px; border-radius:6px; font-size:12px; display:inline-flex; align-items:center; gap:6px;">
      ${f.name.substring(0,15)}... <b style="cursor:pointer; color:red;" onclick="removeFile(${i})">✕</b>
    </span>
  `).join('');
}

function removeFile(i) { uploadedFiles.splice(i, 1); renderFiles(); }

function addPiece() {
  pieceCount++;
  const html = `
    <div class="piece-row" data-piece-id="${pieceCount}">
      <div><input type="text" class="piece-des" placeholder="Désignation" required></div>
      <div><input type="text" class="piece-ref" placeholder="OEM"></div>
      <div><input type="number" class="piece-qte" value="1" min="1" required></div>
      <div>
        <select class="piece-urg">
          <option value="Normal">Normal</option>
          <option value="Urgent">Urgent ⚡</option>
        </select>
      </div>
      <button type="button" class="btn-remove" onclick="removePiece(this)">✕</button>
    </div>
  `;
  document.getElementById('piecesContainer').insertAdjacentHTML('beforeend', html);
  updateRemoveButtons();
}

function removePiece(btn) { btn.closest('.piece-row').remove(); updateRemoveButtons(); }

function updateRemoveButtons() {
  const rows = document.querySelectorAll('.piece-row');
  rows.forEach(row => {
    const btn = row.querySelector('.btn-remove');
    if(!btn) return;
    btn.style.opacity = rows.length === 1 ? '0' : '1';
    btn.style.pointerEvents = rows.length === 1 ? 'none' : 'auto';
  });
}

/* SUIVI CLIENT COMPLET : DEMANDE -> DEVIS -> COMMANDE -> LIVRAISON -> FACTURE */
function trackDossier() {
  const num = document.getElementById('trackingInput').value.trim();
  if (!num) {
    showToast('Veuillez saisir un numéro de demande', 'error');
    return;
  }

  const demandes = JSON.parse(localStorage.getItem('demandes') || '[]');
  const demande = demandes.find(d => d.num === num);

  if (!demande) {
    showToast('Numéro introuvable dans le système.', 'error');
    document.getElementById('clientDashboard').classList.remove('show');
    return;
  }

  // Affichage des informations client
  document.getElementById('dashClient').textContent = demande.client;
  document.getElementById('dashContact').textContent = `${demande.email} | ${demande.telephone}`;
  document.getElementById('dashVehicule').textContent = demande.vehicule;
  document.getElementById('dashAnnee').textContent = `Année: ${demande.annee}`;
  document.getElementById('dashNbPieces').textContent = demande.pieces.length;
  const urgentes = demande.pieces.filter(p => p.urg === 'Urgent').length;
  document.getElementById('dashUrgence').textContent = urgentes > 0 ? `${urgentes} pièce(s) urgente(s)` : 'Toutes normales';

  // 1. DEMANDE DE DEVIS (TOUJOURS ACTIVE - étape 1)
  const dateDevis = new Date(demande.timestamp);
  document.getElementById('dateDevis').textContent = dateDevis.toLocaleDateString('fr-FR') + ' à ' + dateDevis.toLocaleTimeString('fr-FR', {hour:'2-digit', minute:'2-digit'});

  // 2. ANALYSE (Simulation: 3-4 heures après demande)
  const dateAnalyse = new Date(dateDevis.getTime() + 3 * 60 * 60 * 1000);
  document.getElementById('dateAnalyse').textContent = dateAnalyse.toLocaleDateString('fr-FR') + ' à ' + dateAnalyse.toLocaleTimeString('fr-FR', {hour:'2-digit', minute:'2-digit'});
  
  if (demande.statut === 'Analysée') {
    document.getElementById('timelineAnalyse').classList.add('active');
    document.getElementById('badgeAnalyse').className = 'status-badge badge-success';
    document.getElementById('badgeAnalyse').textContent = 'COMPLÉTÉE';
  }

  // 3. DEVIS PROPOSÉ (Simulation: 5-6 heures après demande)
  const dateDevisPropose = new Date(dateDevis.getTime() + 5 * 60 * 60 * 1000);
  document.getElementById('dateDevisPropose').textContent = dateDevisPropose.toLocaleDateString('fr-FR') + ' à ' + dateDevisPropose.toLocaleTimeString('fr-FR', {hour:'2-digit', minute:'2-digit'});
  
  if (demande.statut === 'Devis Proposé' || demande.statut === 'Devis Accepté') {
    document.getElementById('timelineDevisPropose').classList.add('active');
    document.getElementById('badgeDevisPropose').className = demande.statut === 'Devis Accepté' ? 'status-badge badge-success' : 'status-badge badge-process';
    document.getElementById('badgeDevisPropose').textContent = demande.statut === 'Devis Accepté' ? 'VALIDÉ' : 'EN ATTENTE';
    document.getElementById('invoiceContainer1').innerHTML = '<a href="#" class="doc-link" onclick="alert(\'Devis PDF disponible à télécharger...\')">📄 Télécharger le Devis PDF</a>';
  }

  // 4. COMMANDE CONFIRMÉE (Si devis accepté)
  if (demande.commandeStatus === 'Confirmée' || demande.commandeStatus === 'En Préparation' || demande.commandeStatus === 'Expédiée') {
    document.getElementById('timelineCommande').classList.add('active');
    const dateCommande = new Date(dateDevisPropose.getTime() + 2 * 60 * 60 * 1000);
    document.getElementById('dateCommande').textContent = dateCommande.toLocaleDateString('fr-FR');
    document.getElementById('badgeCommande').className = 'status-badge badge-success';
    document.getElementById('badgeCommande').textContent = 'CRÉÉE';
    document.getElementById('orderInfoContainer').innerHTML = `
      <div style="margin-top:8px; font-size:13px; color:var(--text-muted);">
        <strong>Commande N°:</strong> CMD-${demande.num.split('-')[1]}<br>
        <strong>Montant:</strong> ${(demande.pieces.length * 35).toFixed(2)} TND
      </div>
    `;
  }

  // 5. PRÉPARATION
  if (demande.commandeStatus === 'En Préparation' || demande.commandeStatus === 'Expédiée') {
    document.getElementById('timelinePrepare').classList.add('active');
    const datePrepare = new Date(dateDevisPropose.getTime() + 12 * 60 * 60 * 1000);
    document.getElementById('datePrepare').textContent = datePrepare.toLocaleDateString('fr-FR');
    document.getElementById('badgePrepare').className = demande.commandeStatus === 'Expédiée' ? 'status-badge badge-success' : 'status-badge badge-process';
    document.getElementById('badgePrepare').textContent = demande.commandeStatus === 'Expédiée' ? 'COMPLÉTÉE' : 'EN COURS';
  }

  // 6. EXPÉDITION
  if (demande.commandeStatus === 'Expédiée') {
    document.getElementById('timelineShipped').classList.add('active');
    const dateShipped = new Date(dateDevisPropose.getTime() + 24 * 60 * 60 * 1000);
    document.getElementById('dateShipped').textContent = dateShipped.toLocaleDateString('fr-FR');
    document.getElementById('badgeShipped').className = 'status-badge badge-shipped';
    document.getElementById('badgeShipped').textContent = 'EN ROUTE';
    document.getElementById('shippingContainer').innerHTML = `
      <div style="margin-top:8px; font-size:13px; color:var(--text-muted);">
        <strong>Transporteur:</strong> STEG LOGISTIQUE<br>
        <strong>Suivi:</strong> <a href="#" style="color:var(--primary); text-decoration:none;" onclick="alert('Lien de suivi externe...')">TRK#2026070567</a>
      </div>
    `;
  }

  // 7. LIVRAISON
  if (demande.deliveryStatus === 'Livrée') {
    document.getElementById('timelineDelivery').classList.add('active');
    const dateDelivery = new Date(dateDevisPropose.getTime() + 48 * 60 * 60 * 1000);
    document.getElementById('dateDelivery').textContent = dateDelivery.toLocaleDateString('fr-FR');
    document.getElementById('badgeDelivery').className = 'status-badge badge-delivered';
    document.getElementById('badgeDelivery').textContent = 'LIVRÉE';
  }

  // 8. FACTURE & PAIEMENT
  if (demande.factureStatus === 'En attente' || demande.factureStatus === 'Payée') {
    document.getElementById('timelineInvoice').classList.add('active');
    const dateInvoice = new Date(dateDevisPropose.getTime() + 48 * 60 * 60 * 1000);
    document.getElementById('dateInvoice').textContent = dateInvoice.toLocaleDateString('fr-FR');
    document.getElementById('badgeInvoice').className = demande.factureStatus === 'Payée' ? 'status-badge badge-success' : 'status-badge badge-process';
    document.getElementById('badgeInvoice').textContent = demande.factureStatus === 'Payée' ? 'PAYÉE' : 'EN ATTENTE PAIEMENT';
    document.getElementById('invoiceContainer2').innerHTML = `
      <div style="margin-top:8px; font-size:13px; color:var(--text-muted);">
        <strong>Facture N°:</strong> FAC-${demande.num.split('-')[1]}<br>
        <a href="#" class="doc-link" onclick="alert(\'Facture PDF disponible...\')">📄 Télécharger la Facture PDF</a>
      </div>
    `;
  }

  document.getElementById('clientDashboard').classList.add('show');
  showToast('Dossier client chargé avec succès! ✓', 'success');
}

function submitDemande(e) {
  e.preventDefault();
  const now = new Date();
  const num = 'DEM-' + now.toISOString().slice(0,10).replace(/-/g,'') + '-' + String(Math.floor(Math.random()*900)+100);
  
  const pieces = [];
  document.querySelectorAll('.piece-row').forEach(row => {
    const des = row.querySelector('.piece-des').value;
    if (des) {
      pieces.push({
        des,
        ref: row.querySelector('.piece-ref').value,
        qte: row.querySelector('.piece-qte').value,
        urg: row.querySelector('.piece-urg').value
      });
    }
  });

  const demande = {
    num: num,
    date: now.toLocaleDateString('fr-FR'),
    heure: now.toLocaleTimeString('fr-FR', {hour:'2-digit', minute:'2-digit'}),
    timestamp: now.toISOString(),
    client: document.getElementById('nom').value,
    email: document.getElementById('email').value,
    telephone: document.getElementById('telephone').value,
    vehicule: document.getElementById('marque').value + ' ' + document.getElementById('modele').value,
    annee: document.getElementById('annee').value,
    pieces: pieces,
    files: uploadedFiles,
    message: document.getElementById('message').value,
    statut: 'Analysée',
    commandeStatus: 'Confirmée',
    factureStatus: 'En attente de paiement',
    deliveryStatus: 'Expédiée'
  };

  const demandes = JSON.parse(localStorage.getItem('demandes') || '[]');
  demandes.unshift(demande);
  localStorage.setItem('demandes', JSON.stringify(demandes));

  document.getElementById('numDemande').textContent = num;
  document.getElementById('demandeForm').style.display = 'none';
  document.getElementById('confirmation').classList.add('show');
  window.scrollTo({ top: 0, behavior: 'smooth' });
  setupConfirmationActions(demande);
  return false;
}

function setupConfirmationActions(demande) {
  const bodyText = `🔔 NOUVELLE DEMANDE : ${demande.num}\nClient: ${demande.client}\nVéhicule: ${demande.vehicule}\nPièces: ${demande.pieces.length} article(s).\n\nConsultez le suivi sur : https://autop.tn avec le numéro: ${demande.num}`;
  document.getElementById('btnEmailAutop').onclick = () => {
    window.open(`mailto:comptoir.distribution@autop.tn?subject=Demande ${demande.num}&body=${encodeURIComponent(bodyText)}`);
  };
  document.getElementById('btnWhats1').onclick = () => {
    window.open(`https://wa.me/21698774525?text=${encodeURIComponent(bodyText)}`);
  };
}

function nouvelleDemande() {
  document.getElementById('demandeForm').reset();
  uploadedFiles = [];
  renderFiles();
  document.getElementById('demandeForm').style.display = 'block';
  document.getElementById('confirmation').classList.remove('show');
  document.getElementById('trackingInput').value = '';
  document.getElementById('clientDashboard').classList.remove('show');
}

document.addEventListener('DOMContentLoaded', updateRemoveButtons);
</script>
</body>
</html>