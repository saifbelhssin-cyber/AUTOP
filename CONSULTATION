</div>

<!-- HEADER -->
<header class="header">
  <div class="header-inner">
    <div class="logo">
      <svg width="140" height="80" viewBox="0 0 350 200" xmlns="http://www.w3.org/2000/svg">
        <!-- AUTOP LOGO - Simplified version -->
        <text x="175" y="120" font-size="90" font-weight="bold" text-anchor="middle" fill="#d32f2f" font-family="Arial">AUTOP</text>
        <text x="175" y="155" font-size="16" text-anchor="middle" fill="#333" font-family="Arial" font-style="italic">AUTomotive Premium</text>
        <circle cx="280" cy="80" r="25" fill="none" stroke="#d32f2f" stroke-width="2"/>
        <line x1="280" y1="80" x2="295" y2="80" stroke="#d32f2f" stroke-width="3"/>
      </svg>
    </div>
