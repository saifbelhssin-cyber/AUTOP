<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>AUTOP — Demande de devis & Espace Suivi</title>
  <style>
    :root {
      --bg: #f8fafc;
      --surface: #ffffff;
      --text: #0f172a;
      --text-muted: #64748b;
      --primary: #be123c;       /* Rouge auto premium */
      --primary-hover: #9f1239;
      --dark: #0f172a;          /* Ardoise/Bleu nuit chic */
      --border: #e2e8f0;
      --border-focus: #be123c;
      --success: #10b981;
      --warning: #f59e0b;
      --info: #0284c7;
      --radius: 12px;
      --shadow: 0 4px 6px -1px rgb(0 0 0 / 0.05), 0 2px 4px -2px rgb(0 0 0 / 0.05);
      --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.5;
    }

    /* TOP BAR */
    .top-bar {
      background: var(--dark);
      padding: 10px 24px;
      text-align: center;
      font-size: 13px;
      color: #94a3b8;
      border-bottom: 1px solid #1e293b;
    }
    .top-bar a {
      color: #f1f5f9;
      text-decoration: none;
      margin: 0 12px;
      font-weight: 500;
      transition: color 0.2s;
    }
    .top-bar a:hover { color: var(--primary); }

    /* HEADER */
    .header {
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      padding: 16px 24px;
      position: sticky;
      top: 0;
      z-index: 100;
      box-shadow: var(--shadow);
    }
    .header-inner {
      max-width: 1200px;
      margin: 0 auto;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 24px;
    }
    .logo-container {
      display: flex;
      align-items: center;
    }

    .header-right {
      display: flex;
      align-items: center;
      gap: 20px;
    }
    .contact-icons {
      display: flex;
      gap: 10px;
    }
    .contact-icons a {
      width: 40px;
      height: 40px;
      border-radius: var(--radius);
      background: #f1f5f9;
      color: var(--dark);
      display: flex;
      align-items: center;
      justify-content: center;
      text-decoration: none;
      font-size: 18px;
      transition: all 0.2s;
    }
    .contact-icons a:hover {
      background: var(--primary);
      color: white;
      transform: translateY(-2px);
    }

    .nav-links a {
      color: var(--dark);
      text-decoration: none;
      padding: 10px 20px;
      border-radius: var(--radius);
      font-size: 14px;
      font-weight: 600;
      transition: all 0.2s;
      border: 1px solid var(--dark);
    }
    .nav-links a:hover { 
      background: var(--dark);
      color: white;
    }

    /* TRACKING / ESPACE CLIENT */
    .tracking-section {
      background: #f1f5f9;
      padding: 32px 0;
      border-bottom: 1px solid var(--border);
    }
    .tracking-container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 24px;
    }
    .tracking-card {
      background: var(--surface);
      padding: 24px;
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      border: 1px solid var(--border);
    }
    .tracking-card h3 {
      color: var(--dark);
      margin-bottom: 16px;
      font-size: 18px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .search-group {
      display: flex;
      gap: 12px;
    }
    .search-group input {
      flex: 1;
      padding: 12px 16px;
      border: 1px solid var(--border);
      border-radius: var(--radius);
      font-size: 14px;
    }
    .search-group input:focus {
      outline: none;
      border-color: var(--border-focus);
      box-shadow: 0 0 0 3px rgba(190, 18, 60, 0.1);
    }
    .search-btn {
      padding: 12px 24px;
      background: var(--dark);
      color: white;
      border: none;
      border-radius: var(--radius);
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s;
    }
    .search-btn:hover { background: var(--primary); }

    /* DASHBOARD CLIENT DE VISU */
    .client-dashboard {
      display: none;
      margin-top: 24px;
      animation: fadeIn 0.4s ease-out;
    }
    .client-dashboard.show { display: block; }
    
    /* TIMELINE DE SUIVI */
    .timeline {
      position: relative;
      padding: 20px 0;
      margin-top: 24px;
    }
    .timeline::before {
      content: '';
      position: absolute;
      left: 30px;
      top: 0;
      bottom: 0;
      width: 2px;
      background: var(--border);
    }
    .timeline-item {
      margin-bottom: 30px;
      padding-left: 80px;
      position: relative;
    }
    .timeline-item::before {
      content: '';
      position: absolute;
      left: 18px;
      top: 5px;
      width: 24px;
      height: 24px;
      border-radius: 50%;
      background: #e2e8f0;
      border: 3px solid var(--surface);
    }
    .timeline-item.active::before {
      background: var(--success);
    }
    .timeline-item.active .timeline-title { color: var(--success); font-weight: 700; }
    .timeline-item.active .timeline-dot { background: var(--success); }
    
    .timeline-dot {
      position: absolute;
      left: 21px;
      top: 8px;
      width: 18px;
      height: 18px;
      background: var(--border);
      border-radius: 50%;
    }
    
    .timeline-title {
      font-size: 16px;
      font-weight: 600;
      color: var(--dark);
      margin-bottom: 4px;
    }
    .timeline-desc {
      font-size: 13px;
      color: var(--text-muted);
      margin-bottom: 8px;
    }
    .timeline-date {
      font-size: 12px;
      color: #cbd5e1;
      font-weight: 500;
    }

    .status-badge {
      display: inline-block;
      padding: 6px 12px;
      border-radius: 50px;
      font-size: 12px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    .badge-pending { background: #fef3c7; color: #d97706; }
    .badge-process { background: #e0f2fe; color: #0369a1; }
    .badge-success { background: #d1fae5; color: #047857; }
    .badge-shipped { background: #f3e8ff; color: #7c3aed; }
    .badge-delivered { background: #dcfce7; color: #166534; }

    .info-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 16px;
      margin-top: 20px;
    }
    .info-box {
      background: #f8fafc;
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 16px;
    }
    .info-box-title {
      font-size: 13px;
      text-transform: uppercase;
      color: var(--text-muted);
      letter-spacing: 0.05em;
      margin-bottom: 8px;
    }
    .info-box-value {
      font-size: 16px;
      font-weight: 700;
      color: var(--dark);
    }
    .info-box-desc {
      font-size: 13px;
      color: var(--text-muted);
      margin-top: 8px;
    }

    .doc-link {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      color: var(--primary);
      text-decoration: none;
      font-weight: 600;
      font-size: 14px;
      margin-top: 8px;
    }
    .doc-link:hover { text-decoration: underline; }

    /* HERO */
    .hero {
      padding: 56px 24px;
      text-align: center;
      max-width: 800px;
      margin: 0 auto;
    }
    .hero h1 { 
      font-size: 36px; 
      font-weight: 800; 
      margin-bottom: 12px;
      color: var(--dark);
      letter-spacing: -0.02em;
    }
    .hero p { 
      color: var(--text-muted); 
      font-size: 16px; 
      margin-bottom: 24px;
    }
    .trust-badges {
      display: flex;
      justify-content: center;
      gap: 24px;
      flex-wrap: wrap;
      font-size: 14px;
      color: var(--dark);
      font-weight: 500;
    }
    .trust-badge span { color: var(--primary); font-weight: 700; }

    /* FORM & CONTAINER */
    .container {
      max-width: 1000px;
      margin: 0 auto;
      padding: 0 24px 60px;
    }
    .form-card {
      background: var(--surface);
      border-radius: var(--radius);
      padding: 32px;
      box-shadow: var(--shadow-lg);
      border: 1px solid var(--border);
    }
    .form-section-title {
      font-size: 18px;
      color: var(--dark);
      margin-bottom: 20px;
      padding-bottom: 8px;
      border-bottom: 2px solid var(--border);
    }
    .form-row {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 20px;
      margin-bottom: 24px;
    }
    label {
      display: block;
      margin-bottom: 8px;
      color: var(--dark);
      font-weight: 600;
      font-size: 13px;
    }
    .required::after { content: ' *'; color: var(--primary); }

    input, select, textarea {
      width: 100%;
      padding: 12px;
      border: 1px solid var(--border);
      border-radius: var(--radius);
      font-size: 14px;
      background: #f8fafc;
      color: var(--text);
      transition: all 0.2s;
    }
    input:focus, select:focus, textarea:focus {
      outline: none;
      border-color: var(--border-focus);
      background: var(--surface);
      box-shadow: 0 0 0 3px rgba(190, 18, 60, 0.1);
    }

    /* PIECES CONTAINER */
    .pieces-section {
      background: #f8fafc;
      padding: 24px;
      border-radius: var(--radius);
      border: 1px solid var(--border);
      margin-bottom: 24px;
    }
    .piece-row {
      display: grid;
      grid-template-columns: 2fr 1fr 1fr 1fr 44px;
      gap: 12px;
      align-items: end;
      margin-bottom: 12px;
    }
    .btn-remove {
      width: 42px;
      height: 42px;
      border: 1px solid #fee2e2;
      border-radius: var(--radius);
      background: #fef2f2;
      color: #ef4444;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.2s;
    }
    .btn-remove:hover { background: #fee2e2; }

    .btn-add-piece {
      background: var(--surface);
      color: var(--dark);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 10px 20px;
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      box-shadow: var(--shadow);
      transition: all 0.2s;
    }
    .btn-add-piece:hover { background: #f1f5f9; }

    /* ZONE TELECHARGEMENT */
    .files-section {
      border: 2px dashed var(--border);
      background: #f8fafc;
      border-radius: var(--radius);
      padding: 32px;
      margin-bottom: 24px;
      text-align: center;
      transition: border-color 0.2s;
    }
    .files-section:hover { border-color: var(--primary); }
    .file-upload-btn {
      padding: 10px 20px;
      background: var(--surface);
      color: var(--dark);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      cursor: pointer;
      font-weight: 600;
      box-shadow: var(--shadow);
    }

    /* ACTION BUTTONS */
    .actions {
      display: flex;
      gap: 12px;
      justify-content: flex-end;
    }
    .btn {
      padding: 14px 28px;
      border: none;
      border-radius: var(--radius);
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s;
    }
    .btn-primary {
      background: var(--primary);
      color: white;
    }
    .btn-primary:hover {
      background: var(--primary-hover);
      transform: translateY(-1px);
    }
    .btn-outline {
      border: 1px solid var(--border);
      color: var(--dark);
      background: var(--surface);
    }
    .btn-outline:hover { background: #f1f5f9; }

    /* CONFIRMATION MODAL */
    .confirmation {
      display: none;
      position: fixed;
      top: 0; left: 0; right: 0; bottom: 0;
      background: rgba(15, 23, 42, 0.6);
      backdrop-filter: blur(4px);
      z-index: 500;
      align-items: center;
      justify-content: center;
    }
    .confirmation.show { display: flex; }
    .confirmation-content {
      background: var(--surface);
      border-radius: 16px;
      padding: 40px;
      max-width: 550px;
      width: 90%;
      text-align: center;
      box-shadow: var(--shadow-lg);
    }
    .num {
      font-family: monospace;
      font-size: 20px;
      font-weight: 700;
      color: var(--primary);
      background: #fff1f2;
      padding: 14px;
      border-radius: var(--radius);
      margin: 16px 0;
      border: 1px solid #fecdd3;
    }

    /* FOOTER */
    .footer {
      background: var(--dark);
      padding: 48px 24px;
      text-align: center;
      color: #94a3b8;
      font-size: 14px;
    }
    .footer-links a {
      color: #f1f5f9;
      text-decoration: none;
      margin: 0 10px;
    }
    .footer-links a:hover { color: var(--primary); }

    /* TOAST */
    .toast {
      position: fixed;
      bottom: 24px; right: 24px;
      padding: 14px 24px;
      border-radius: var(--radius);
      color: white;
      font-size: 14px;
      font-weight: 600;
      box-shadow: var(--shadow-lg);
      opacity: 0;
      transform: translateY(20px);
      transition: all 0.3s;
      z-index: 2000;
    }
    .toast.show { opacity: 1; transform: translateY(0); }
    .toast.success { background: var(--success); }
    .toast.error { background: #ef4444; }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }

    /* RESPONSIVE */
    @media (max-width: 768px) {
      .header-inner { flex-direction: column; gap: 16px; }
      .search-group { flex-direction: column; }
      .piece-row { grid-template-columns: 1fr; gap: 8px; }
      .btn-remove { width: 100%; }
      .actions { flex-direction: column; }
      .btn { width: 100%; }
      .timeline::before { left: 15px; }
      .timeline-item { padding-left: 60px; }
      .timeline-item::before { left: 5px; }
      .timeline-dot { left: 8px; }
    }
  </style>
</head>
