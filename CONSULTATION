          <div class="timeline-item active">
            <div class="timeline-content">
              <div class="timeline-number">1</div>
              <div class="timeline-title-text">✓ Demande Reçue</div>
              <div class="timeline-desc" id="statusDevis1">Votre demande enregistrée</div>
              <div class="timeline-date" id="dateDevis" style="font-size:12px; color:#999; margin-top:10px;">-</div>
              <span class="status-badge badge-success" id="badgeDevis">CONFIRMÉE</span>
            </div>
          </div>

          <div class="timeline-item" id="timelineAnalyse">
            <div class="timeline-content">
              <div class="timeline-number">2</div>
              <div class="timeline-title-text">Analyse</div>
              <div class="timeline-desc">Étude de votre demande</div>
              <div class="timeline-date" id="dateAnalyse" style="font-size:12px; color:#999; margin-top:10px;">-</div>
              <span class="status-badge badge-process" id="badgeAnalyse">EN COURS</span>
            </div>
          </div>

          <div class="timeline-item" id="timelineDevisPropose">
            <div class="timeline-content">
              <div class="timeline-number">3</div>
              <div class="timeline-title-text">Devis Envoyé</div>
              <div class="timeline-desc">Proposition commerciale</div>
              <div class="timeline-date" id="dateDevisPropose" style="font-size:12px; color:#999; margin-top:10px;">-</div>
              <span class="status-badge badge-pending" id="badgeDevisPropose">ATTENTE</span>
            </div>
          </div>

          <div class="timeline-item" id="timelineCommande">
            <div class="timeline-content">
              <div class="timeline-number">4</div>
              <div class="timeline-title-text">Commande Confirmée</div>
              <div class="timeline-desc">Pièces validées</div>
              <div class="timeline-date" id="dateCommande" style="font-size:12px; color:#999; margin-top:10px;">-</div>
              <span class="status-badge badge-pending" id="badgeCommande">ATTENTE</span>
            </div>
          </div>

          <div class="timeline-item" id="timelinePrepare">
            <div class="timeline-content">
              <div class="timeline-number">5</div>
              <div class="timeline-title-text">Préparation</div>
              <div class="timeline-desc">Pièces emballées</div>
              <div class="timeline-date" id="datePrepare" style="font-size:12px; color:#999; margin-top:10px;">-</div>
              <span class="status-badge badge-pending" id="badgePrepare">ATTENTE</span>
            </div>
          </div>

          <div class="timeline-item" id="timelineShipped">
            <div class="timeline-content">
              <div class="timeline-number">6</div>
              <div class="timeline-title-text">🚚 Expédition</div>
              <div class="timeline-desc">Colis en route</div>
              <div class="timeline-date" id="dateShipped" style="font-size:12px; color:#999; margin-top:10px;">-</div>
              <span class="status-badge badge-shipped" id="badgeShipped">ATTENTE</span>
            </div>
          </div>

          <div class="timeline-item" id="timelineDelivery">
            <div class="timeline-content">
              <div class="timeline-number">7</div>
              <div class="timeline-title-text">✓ Livré</div>
              <div class="timeline-desc">Colis reçu</div>
              <div class="timeline-date" id="dateDelivery" style="font-size:12px; color:#999; margin-top:10px;">-</div>
              <span class="status-badge badge-pending" id="badgeDelivery">ATTENTE</span>
            </div>
          </div>

          <div class="timeline-item" id="timelineInvoice">
            <div class="timeline-content">
              <div class="timeline-number">8</div>
              <div class="timeline-title-text">💳 Facture</div>
              <div class="timeline-desc">Paiement et suivi</div>
              <div class="timeline-date" id="dateInvoice" style="font-size:12px; color:#999; margin-top:10px;">-</div>
              <span class="status-badge badge-pending" id="badgeInvoice">ATTENTE</span>
            </div>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>

<!-- FORM SECTION -->
<section class="form-section">
  <div class="container">
    <h2 class="section-title">Faire une demande</h2>
    <p class="section-subtitle">Remplissez le formulaire ci-dessous pour obtenir un devis personnalisé</p>

    <form id="demandeForm" class="form-card" onsubmit="return submitDemande(event)">
      
      <!-- INFOS CLIENT -->
      <div style="margin-bottom: 40px;">
        <div class="form-group-title">📋 Vos informations</div>
        <div class="form-row">
          <div class="form-group">
            <label class="required">Nom complet</label>
            <input type="text" id="nom" required>
          </div>
          <div class="form-group">
            <label class="required">Email</label>
            <input type="email" id="email" required>
          </div>
          <div class="form-group">
            <label class="required">Téléphone</label>
            <input type="tel" id="telephone" required>
          </div>
        </div>
      </div>

      <!-- INFOS VEHICULE -->
      <div style="margin-bottom: 40px;">
        <div class="form-group-title">🚗 Véhicule</div>
        <div class="form-row">
          <div class="form-group">
            <label class="required">Marque</label>
            <input type="text" id="marque" placeholder="Volkswagen" required>
          </div>
          <div class="form-group">
            <label class="required">Modèle</label>
            <input type="text" id="modele" placeholder="Golf 8" required>
          </div>
          <div class="form-group">
            <label class="required">Année</label>
            <input type="number" id="annee" min="1990" max="2050" placeholder="2022" required>
          </div>
          <div class="form-group">
            <label>Kilométrage</label>
            <input type="number" id="kilometrage" placeholder="85000">
          </div>
        </div>
      </div>

      <!-- PIECES -->
      <div class="pieces-section">
        <div class="form-group-title" style="border-bottom: none; margin-bottom: 20px;">🔧 Pièces demandées</div>
        <div id="piecesContainer">
          <div class="piece-row" data-piece-id="1">
            <input type="text" class="piece-des" placeholder="Désignation" required>
            <input type="text" class="piece-ref" placeholder="Référence OEM">
            <input type="number" class="piece-qte" value="1" min="1" required>
            <select class="piece-urg">
              <option value="Normal">Normal</option>
              <option value="Urgent">Urgent ⚡</option>
            </select>
            <button type="button" class="btn-remove" onclick="removePiece(this)" style="opacity:0; pointer-events:none;">✕</button>
          </div>
        </div>
        <button type="button" class="btn-add-piece" onclick="addPiece()">+ Ajouter pièce</button>
      </div>

      <!-- FILES -->
      <div class="files-section">
        <h4 style="margin-bottom: 15px; color: var(--accent); font-size: 18px;">📸 Documents (Optionnel)</h4>
        <p style="color: var(--gray-500); margin-bottom: 20px;">Carte grise, photos, etc.</p>
        <input type="file" id="fileInput" multiple accept="image/*,.pdf" style="display:none;" onchange="handleFileSelect(event)">
        <button type="button" class="file-upload-btn" onclick="document.getElementById('fileInput').click()">📁 Choisir fichiers</button>
        <div class="files-list" id="filesList"></div>
      </div>

      <!-- MESSAGE -->
      <div style="margin-bottom: 40px;">
        <div class="form-group">
          <label>Message supplémentaire</label>
          <textarea id="message" placeholder="Informations utiles..."></textarea>
        </div>
      </div>

      <!-- ACTIONS -->
      <div class="actions">
        <button type="reset" class="btn btn-outline">Annuler</button>
        <button type="submit" class="btn btn-primary">📤 Envoyer demande</button>
      </div>
    </form>
  </div>
</section>

<!-- MODAL -->
<div class="modal" id="confirmation">
  <div class="modal-content">
    <div class="modal-icon">🎉</div>
    <h2 class="modal-title">Demande reçue!</h2>
    <p style="color: var(--gray-500); margin-bottom: 20px;">Voici votre numéro de suivi :</p>
    <div class="modal-number" id="numDemande">-</div>
    <p style="color: var(--gray-500); font-size: 14px;">Gardez ce numéro pour suivre votre commande</p>
    <div class="modal-buttons">
      <button class="btn btn-outline" id="btnEmailAutop">✉️ Email</button>
      <button class="btn btn-outline" id="btnWhats1">💬 WhatsApp</button>
      <button class="btn btn-primary" onclick="nouvelleDemande()" style="flex: 2;">➕ Nouvelle demande</button>
    </div>
  </div>
</div>

<!-- FOOTER -->
<footer>
  <p>© 2026 AUTOP Premium | <a href="mailto:comptoir.distribution@autop.tn">Contact</a> | <a href="admin.html">Admin</a></p>
</footer>

<div class="toast" id="toast"></div>

<script>
let pieceCount = 1;
let uploadedFiles = [];

function showToast(msg, type = 'success') {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.className = `toast ${type} show`;
  setTimeout(() => t.classList.remove('show'), 4000);
}

function handleFileSelect(e) {
  Array.from(e.target.files).forEach(file => {
    if(file.size > 5 * 1024 * 1024) {
      showToast(`${file.name} trop volumineux`, 'error');
      return;
    }
    const reader = new FileReader();
    reader.onload = evt => {
      uploadedFiles.push({ name: file.name, data: evt.target.result });
      renderFiles();
    };
    reader.readAsDataURL(file);
  });
  e.target.value = '';
}

function renderFiles() {
  const list = document.getElementById('filesList');
  list.innerHTML = uploadedFiles.map((f, i) => `
    <div class="file-item">
      📄 ${f.name.substring(0,20)}...
      <span class="file-remove" onclick="removeFile(${i})">✕</span>
    </div>
  `).join('');
}

function removeFile(i) { uploadedFiles.splice(i, 1); renderFiles(); }

function addPiece() {
  pieceCount++;
  const html = `
    <div class="piece-row" data-piece-id="${pieceCount}">
      <input type="text" class="piece-des" placeholder="Désignation" required>
      <input type="text" class="piece-ref" placeholder="OEM">
      <input type="number" class="piece-qte" value="1" min="1" required>
      <select class="piece-urg">
        <option value="Normal">Normal</option>
        <option value="Urgent">Urgent ⚡</option>
      </select>
      <button type="button" class="btn-remove" onclick="removePiece(this)">✕</button>
    </div>
  `;
  document.getElementById('piecesContainer').insertAdjacentHTML('beforeend', html);
  updateRemoveButtons();
}

function removePiece(btn) { btn.closest('.piece-row').remove(); updateRemoveButtons(); }

function updateRemoveButtons() {
  const rows = document.querySelectorAll('.piece-row');
  rows.forEach(row => {
    const btn = row.querySelector('.btn-remove');
    btn.style.opacity = rows.length === 1 ? '0' : '1';
    btn.style.pointerEvents = rows.length === 1 ? 'none' : 'auto';
  });
}

function trackDossier() {
  const num = document.getElementById('trackingInput').value.trim();
  if (!num) {
    showToast('Entrez un numéro de demande', 'error');
    return;
  }

  const demandes = JSON.parse(localStorage.getItem('demandes') || '[]');
  const demande = demandes.find(d => d.num === num);

  if (!demande) {
    showToast('Numéro introuvable', 'error');
    document.getElementById('clientDashboard').classList.remove('show');
    return;
  }

  document.getElementById('dashClient').textContent = demande.client;
  document.getElementById('dashContact').textContent = `${demande.email} | ${demande.telephone}`;
  document.getElementById('dashVehicule').textContent = demande.vehicule;
  document.getElementById('dashAnnee').textContent = `Année: ${demande.annee}`;
  document.getElementById('dashNbPieces').textContent = demande.pieces.length;
  const urgentes = demande.pieces.filter(p => p.urg === 'Urgent').length;
  document.getElementById('dashUrgence').textContent = urgentes > 0 ? `${urgentes} urgente(s)` : 'Toutes normales';

  const dateDevis = new Date(demande.timestamp);
  document.getElementById('dateDevis').textContent = dateDevis.toLocaleDateString('fr-FR');

  const dateAnalyse = new Date(dateDevis.getTime() + 3 * 60 * 60 * 1000);
  document.getElementById('dateAnalyse').textContent = dateAnalyse.toLocaleDateString('fr-FR');
  
  if (demande.statut === 'Analysée') {
    document.getElementById('timelineAnalyse').classList.add('active');
    document.getElementById('badgeAnalyse').className = 'status-badge badge-success';
    document.getElementById('badgeAnalyse').textContent = 'COMPLÉTÉE';
  }

  const dateDevisPropose = new Date(dateDevis.getTime() + 5 * 60 * 60 * 1000);
  document.getElementById('dateDevisPropose').textContent = dateDevisPropose.toLocaleDateString('fr-FR');
  
  if (demande.statut === 'Devis Proposé' || demande.statut === 'Devis Accepté') {
    document.getElementById('timelineDevisPropose').classList.add('active');
    document.getElementById('badgeDevisPropose').className = demande.statut === 'Devis Accepté' ? 'status-badge badge-success' : 'status-badge badge-process';
    document.getElementById('badgeDevisPropose').textContent = demande.statut === 'Devis Accepté' ? 'VALIDÉ' : 'EN ATTENTE';
  }

  if (demande.commandeStatus === 'Confirmée' || demande.commandeStatus === 'En Préparation' || demande.commandeStatus === 'Expédiée') {
    document.getElementById('timelineCommande').classList.add('active');
    const dateCommande = new Date(dateDevisPropose.getTime() + 2 * 60 * 60 * 1000);
    document.getElementById('dateCommande').textContent = dateCommande.toLocaleDateString('fr-FR');
    document.getElementById('badgeCommande').className = 'status-badge badge-success';
    document.getElementById('badgeCommande').textContent = 'CRÉÉE';
  }

  if (demande.commandeStatus === 'En Préparation' || demande.commandeStatus === 'Expédiée') {
    document.getElementById('timelinePrepare').classList.add('active');
    const datePrepare = new Date(dateDevisPropose.getTime() + 12 * 60 * 60 * 1000);
    document.getElementById('datePrepare').textContent = datePrepare.toLocaleDateString('fr-FR');
    document.getElementById('badgePrepare').className = demande.commandeStatus === 'Expédiée' ? 'status-badge badge-success' : 'status-badge badge-process';
    document.getElementById('badgePrepare').textContent = demande.commandeStatus === 'Expédiée' ? 'COMPLÉTÉE' : 'EN COURS';
  }

  if (demande.commandeStatus === 'Expédiée') {
    document.getElementById('timelineShipped').classList.add('active');
    const dateShipped = new Date(dateDevisPropose.getTime() + 24 * 60 * 60 * 1000);
    document.getElementById('dateShipped').textContent = dateShipped.toLocaleDateString('fr-FR');
    document.getElementById('badgeShipped').className = 'status-badge badge-shipped';
    document.getElementById('badgeShipped').textContent = 'EN ROUTE';
  }

  if (demande.deliveryStatus === 'Livrée') {
    document.getElementById('timelineDelivery').classList.add('active');
    const dateDelivery = new Date(dateDevisPropose.getTime() + 48 * 60 * 60 * 1000);
    document.getElementById('dateDelivery').textContent = dateDelivery.toLocaleDateString('fr-FR');
    document.getElementById('badgeDelivery').className = 'status-badge badge-success';
    document.getElementById('badgeDelivery').textContent = 'LIVRÉE';
  }

  if (demande.factureStatus === 'En attente' || demande.factureStatus === 'Payée') {
    document.getElementById('timelineInvoice').classList.add('active');
    const dateInvoice = new Date(dateDevisPropose.getTime() + 48 * 60 * 60 * 1000);
    document.getElementById('dateInvoice').textContent = dateInvoice.toLocaleDateString('fr-FR');
    document.getElementById('badgeInvoice').className = demande.factureStatus === 'Payée' ? 'status-badge badge-success' : 'status-badge badge-process';
    document.getElementById('badgeInvoice').textContent = demande.factureStatus === 'Payée' ? 'PAYÉE' : 'ATTENTE PAIEMENT';
  }

  document.getElementById('clientDashboard').classList.add('show');
  showToast('Dossier chargé ✓', 'success');
}

function submitDemande(e) {
  e.preventDefault();
  const now = new Date();
  const num = 'DEM-' + now.toISOString().slice(0,10).replace(/-/g,'') + '-' + String(Math.floor(Math.random()*900)+100);
  
  const pieces = [];
  document.querySelectorAll('.piece-row').forEach(row => {
    const des = row.querySelector('.piece-des').value;
    if (des) pieces.push({
      des,
      ref: row.querySelector('.piece-ref').value,
      qte: row.querySelector('.piece-qte').value,
      urg: row.querySelector('.piece-urg').value
    });
  });

  const demande = {
    num: num,
    date: now.toLocaleDateString('fr-FR'),
    timestamp: now.toISOString(),
    client: document.getElementById('nom').value,
    email: document.getElementById('email').value,
    telephone: document.getElementById('telephone').value,
    vehicule: document.getElementById('marque').value + ' ' + document.getElementById('modele').value,
    annee: document.getElementById('annee').value,
    pieces: pieces,
    statut: 'Analysée',
    commandeStatus: 'Confirmée',
    factureStatus: 'En attente',
    deliveryStatus: 'Expédiée'
  };

  const demandes = JSON.parse(localStorage.getItem('demandes') || '[]');
  demandes.unshift(demande);
  localStorage.setItem('demandes', JSON.stringify(demandes));

  document.getElementById('numDemande').textContent = num;
  document.getElementById('demandeForm').style.display = 'none';
  document.getElementById('confirmation').classList.add('show');
  setupConfirmationActions(demande);
  return false;
}

function setupConfirmationActions(demande) {
  const msg = `Demande ${demande.num}\nClient: ${demande.client}\nVéhicule: ${demande.vehicule}\n${demande.pieces.length} pièce(s)`;
  document.getElementById('btnEmailAutop').onclick = () => {
    window.open(`mailto:comptoir.distribution@autop.tn?subject=Demande ${demande.num}&body=${encodeURIComponent(msg)}`);
  };
  document.getElementById('btnWhats1').onclick = () => {
    window.open(`https://wa.me/21698774525?text=${encodeURIComponent(msg)}`);
  };
}

function nouvelleDemande() {
  document.getElementById('demandeForm').reset();
  uploadedFiles = [];
  renderFiles();
  document.getElementById('demandeForm').style.display = 'block';
  document.getElementById('confirmation').classList.remove('show');
}

document.addEventListener('DOMContentLoaded', updateRemoveButtons);
</script>
</body>
</html>